{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "bundle": false,
        "maxDuration": 60,
        "memory": 1024,
        "includeFiles": [
          "model/best_model.onnx",
          "lib/**",
          "node_modules/onnxruntime-web/dist/*.wasm",
          "node_modules/onnxruntime-web/dist/*.mjs"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
